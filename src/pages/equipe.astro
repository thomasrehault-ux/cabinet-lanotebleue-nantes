---
import Layout from '../layouts/Layout.astro';

const axes = [
  {
    id: 'psychologie',
    titre: 'Psychologie clinique · psychothérapie',
    soustitre: 'Comprendre, traverser, réparer',
    description: "Travail sur le mental restrictif, la dualité intérieure, la restauration progressive d'une sécurité intérieure et d'une présence à soi unifiée.",
    praticiens: [
      {
        nom: 'Aude Réhault',
        role: 'Psychologue clinicienne · Fondatrice du cabinet',
        photo: '/images/Aude-Rehault.jpg',
        formation: "EPP Paris · DU Psychotraumatologie, Université Paris Descartes · Formation à l'hypnose, IFH · Thérapie rêve éveillé phénoméno-existentiel, IREPHE",
        note: "Fondatrice de La Note Bleue. Auteur d'un ouvrage paru chez Dunod en 2023.",
        doctolib: 'https://www.doctolib.fr/psychologue/nantes/aude-rehault',
      },
      {
        nom: 'Charles-Antoine Menanteau',
        role: 'Psychologue clinicien · Psychothérapeute',
        photo: '/images/Charles-Antoine-Menanteau.jpg',
        formation: "Université Catholique de l'Ouest - IPSA Angers · Thérapie rêve éveillé phénoméno-existentiel, IREPHE · Formation thérapie corps-esprit · CESHUM",
        note: null,
        doctolib: 'https://www.doctolib.fr/psychologue/nantes/charles-antoine-menanteau',
      },
      {
        nom: 'Nathalie Saget',
        role: 'Psychologue clinicienne · Thérapeute conjugale et familiale',
        photo: '/images/Nathalie-Saget.JPG',
        formation: 'DESS Paris 7 · DU Paris 6 · DFSSU Paris 8',
        note: 'Accompagnements des couples et des familles.',
        doctolib: 'https://www.doctolib.fr/psychologue/nantes/nathalie-saget',
      },
    ],
  },
  {
    id: 'dietetique',
    titre: 'Diététique · nutrition',
    soustitre: 'Réapprendre à se nourrir, sans peur',
    description: "Accompagnement alimentaire intégratif, restauration de l'intéroception, travail sur les croyances alimentaires, sortie progressive du contrôle.",
    praticiens: [
      {
        nom: 'Julie Basset',
        role: 'Diététicienne · Micronutritionniste',
        photo: '/images/Julie-Basset.JPG',
        formation: 'BTS Diététique · DU Micronutrition, Université de Bourgogne',
        note: null,
        doctolib: 'https://www.doctolib.fr/dieteticien/nantes/julie-basset-nantes',
      },
      {
        nom: 'Emilie Grasset',
        role: 'Diététicienne · Nutritionniste',
        photo: '/images/Emilie-Grasset.jpg',
        formation: null,
        note: null,
        doctolib: 'https://www.doctolib.fr/dieteticien-nutritionniste/nantes/emilie-grasset',
      },
      {
        nom: 'Marine Boni',
        role: 'Diététicienne · Nutritionniste',
        photo: '/images/Marine-Boni.jpeg',
        formation: null,
        note: null,
        doctolib: 'https://www.doctolib.fr/dieteticien/nantes/marine-boni',
      },
    ],
  },
  {
    id: 'psychomotricite',
    titre: 'Psychomotricité',
    soustitre: 'Réhabiter son corps',
    description: "Travail sur l'enveloppe corporelle, les limites, l'ancrage, la modulation tonique, la restauration d'une sécurité corporelle vécue.",
    praticiens: [
      {
        nom: 'Blanche Augarde-Dollé',
        role: 'Psychomotricienne',
        photo: '/images/Blanche-Augarde-Dolle.jpg',
        formation: 'Institut de Psychomotricité de la Salpêtrière',
        note: 'Pratiques complémentaires : yoga, réflexologie, méditation, mime, relaxation.',
        doctolib: 'https://www.doctolib.fr/psychomotricien/paris/blanche-augarde-dolle',
      },
      {
        nom: 'Séverine Gauvin',
        role: 'Psychomotricienne',
        photo: '/images/Severine-Gauvin.jpg',
        formation: null,
        note: null,
        doctolib: 'https://www.doctolib.fr/psychomotricien/nantes/severine-gauvin',
      },
    ],
  },
];
---

<Layout
  title="Équipe · Cabinet La Note Bleue · Nantes"
  description="Une équipe pluridisciplinaire à Nantes pour les troubles du comportement alimentaire : psychologues, diététiciennes, psychomotriciennes. Prise de rendez-vous par Doctolib."
  canonicalPath="/equipe"
>
  <!-- ========== HERO ========== -->
  <section class="hero hero-page">
    <div class="hero-inner reveal">
      <div class="hero-label">L'équipe</div>
      <h1>Trois axes de soin, <em>une même exigence</em> clinique.</h1>
      <p class="hero-lede">
        Notre équipe pluridisciplinaire travaille en synergie,
        autour d'un projet de soin commun pour chaque patient.
      </p>
    </div>
  </section>

  <!-- ========== AXES ========== -->
  {axes.map((axe) => (
    <section class="axe-section reveal" id={axe.id}>
      <div class="container">
        <div class="axe-header">
          <h2 class="axe-titre">{axe.titre}</h2>
          <p class="axe-soustitre">{axe.soustitre}</p>
        </div>
        <p class="axe-description">{axe.description}</p>

        <div class="praticiens-grid">
          {axe.praticiens.map((p) => (
            <article class="praticien-card">
  <div class="praticien-header">
    {p.photo && <img src={p.photo} alt={p.nom} class="praticien-photo" loading="lazy" />}
    <div class="praticien-ident">
      <h3 class="praticien-nom">{p.nom}</h3>
      <p class="praticien-role">{p.role}</p>
    </div>
  </div>
              {p.formation && <p class="praticien-formation">{p.formation}</p>}
              {p.note && <p class="praticien-note">{p.note}</p>}
              {p.doctolib && p.doctolib !== '#' ? (
                <a href={p.doctolib} class="praticien-doctolib" target="_blank" rel="noopener noreferrer">
                  Prendre rendez-vous sur Doctolib →
                </a>
              ) : (
                <span class="praticien-doctolib praticien-doctolib-placeholder">
                  Prise de rendez-vous à venir
                </span>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}
</Layout>

<style>
  /* ========== CONTAINER (manquant dans Layout, redéfini ici) ========== */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* ========== HERO PAGE — override du hero de la home ========== */
  .hero-page {
    padding: 4.5rem 2rem 5rem;
  }
  .hero-page h1 {
    font-size: clamp(2rem, 4vw, 3.2rem);
    max-width: 900px;
  }
  .hero-page .hero-lede {
    font-size: 1.05rem;
    max-width: 720px;
    margin-bottom: 0;
  }

  /* ========== AXE SECTION ========== */
  .axe-section {
    padding: 6rem 0;
    background: var(--warm-white);
    border-bottom: 1px solid rgba(30, 58, 95, 0.08);
  }

  .axe-section:nth-child(even) {
    background: var(--cream);
  }

  .axe-header {
    margin-bottom: 1.8rem;
  }

.axe-soustitre {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.15rem;
  color: var(--gold);
  font-weight: 400;
}

  .axe-description {
    font-family: var(--font-body);
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 780px;
    margin-bottom: 3.5rem;
    font-weight: 300;
  }

  /* ========== PRATICIENS GRID ========== */
  .praticiens-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

.praticien-card {
  background: #ffffff;
  border: 1px solid rgba(30, 58, 95, 0.1);
  border-top: 3px solid var(--gold);
  border-radius: 10px;   /* ← ajouter cette ligne */
  padding: 2.2rem 2rem;
  box-shadow: 0 2px 8px rgba(30, 58, 95, 0.04);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  display: flex;
  flex-direction: column;
  gap: 0.9rem;
}

  .praticien-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(30, 58, 95, 0.1);
  }
.praticien-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 0.4rem;
}

.praticien-photo {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  border: 2px solid var(--gold);
  box-shadow: 0 2px 6px rgba(30, 58, 95, 0.1);
}

.praticien-ident {
  flex: 1;
  min-width: 0;
}
  .praticien-nom {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--blue-deep);
    line-height: 1.2;
  }

  .praticien-role {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--gold);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .praticien-formation {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 300;
  }

  .praticien-note {
    font-family: var(--font-body);
    font-style: italic;
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 300;
    padding-top: 0.6rem;
    border-top: 1px solid rgba(30, 58, 95, 0.08);
  }

  .praticien-doctolib {
    margin-top: auto;
    padding-top: 1rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--blue-deep);
    text-decoration: none;
    transition: color 0.3s ease;
    align-self: flex-start;
  }

  .praticien-doctolib:hover {
    color: var(--gold);
  }

  .praticien-doctolib-placeholder {
    color: var(--text-tertiary, #8a8a8a);
    font-style: italic;
    font-weight: 300;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 768px) {
    .hero-page {
      padding: 3rem 1.2rem 3.5rem;
    }

    .axe-section {
      padding: 4rem 0;
    }

    .synergie-section {
      padding: 4rem 0;
    }

    .praticiens-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
