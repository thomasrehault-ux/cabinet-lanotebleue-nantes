---
import Layout from '../layouts/Layout.astro';

const axes = [
  {
    numero: '01',
    titre: 'Psychologie clinique · psychothérapie',
    description:
      "Travail sur le mental restrictif, la dualité intérieure, la restauration progressive d'une sécurité intérieure et d'une présence à soi unifiée.",
    praticiens: 'Aude Réhault · Charles-Antoine Menanteau · Nathalie Saget',
  },
  {
    numero: '02',
    titre: 'Diététique · nutrition',
    description:
      "Accompagnement alimentaire intégratif, restauration de l'intéroception, travail sur les croyances alimentaires, sortie progressive du contrôle.",
    praticiens: 'Julie Basset · Marine Boni · Emilie Grasset',
  },
  {
    numero: '03',
    titre: 'Psychomotricité',
    description:
      "Travail sur l'enveloppe corporelle, les limites, l'ancrage, la modulation tonique, la restauration d'une sécurité corporelle vécue.",
    praticiens: 'Blanche Augarde-Dollé · Séverine Gauvin',
  },
];

const reperes = [
  'Cabinet pluridisciplinaire à Nantes',
  "Approche intégrative construite sur 30 ans d'expérience clinique",
  'Prise de rendez-vous directe sur Doctolib',
];

const publics = [
  {
    titre: 'Adolescents et adultes',
    texte:
      "À toute étape de la trajectoire : premiers symptômes, parcours déjà long, sortie d'hospitalisation, rechutes.",
  },
  {
    titre: 'Tous les TCA, y compris les formes peu visibles',
    texte:
      "Anorexie restrictive, boulimie avec ou sans vomissements, hyperphagie, TCA atypiques, obsessions alimentaires sans perte de poids.",
  },
  {
    titre: "L'entourage",
    texte:
      "Les proches peuvent consulter pour comprendre, se repérer, et trouver leur juste place dans l'accompagnement.",
  },
];
---

<Layout
  title="Cabinet La Note Bleue · Nantes | Trajectoire de soin des troubles alimentaires"
  description="Cabinet pluridisciplinaire nantais spécialisé dans la trajectoire de soin des troubles des conduites alimentaires. Psychologie, diététique, psychomotricité, en synergie."
  canonicalPath="/"
>
  <section class="home-hero">
    <div class="home-hero-shell reveal">
      <div class="home-hero-copy">
        <div class="hero-kicker">Cabinet pluridisciplinaire · Nantes · Troubles des conduites alimentaires</div>
        <h1>Une trajectoire de soin <em>plus incarnée</em>, pensée pour durer.</h1>
        <p class="hero-intro">
          Le Cabinet La Note Bleue réunit psychologues, diététiciennes et psychomotriciennes
          autour d'une même conviction clinique : on ne soigne pas durablement un TCA en
          s'occupant seulement des symptômes visibles.
        </p>
        <div class="hero-actions">
          <a
            href="https://www.doctolib.fr/cabinet-pluridisciplinaire/nantes/sos-anor-grand-ouest?pid=practice-103988"
            class="btn-primary"
            target="_blank"
            rel="noopener"
          >
            Prendre rendez-vous
          </a>
          <a href="/parcours" class="btn-secondary">Découvrir l'approche</a>
        </div>
      </div>

      <aside class="hero-panel">
        <div class="hero-panel-label">Repères</div>
        <ul class="hero-panel-list">
          {reperes.map((repere) => <li>{repere}</li>)}
        </ul>
        <div class="hero-panel-note">
          Le cabinet est distinct de l'association La Note Bleue, dédiée à l'information,
          l'orientation et au soutien des personnes concernées et de leur entourage.
        </div>
        <a href="https://association-lanotebleue.fr" target="_blank" rel="noopener" class="hero-panel-link">
          Découvrir l'association
        </a>
      </aside>
    </div>
  </section>

  <section class="home-intent bg-white">
    <div class="inner reveal">
      <div class="section-head home-head">
        <div class="section-head-text">
          <div class="section-label">Le cabinet en quelques mots</div>
          <h2>Soigner les troubles des conduites alimentaires <em>autrement</em></h2>
        </div>
      </div>
      <div class="divider-gold"></div>
      <div class="intent-grid">
        <div class="intent-prose">
          <p>
            Derrière l'anorexie, la boulimie ou l'hyperphagie, il existe souvent une structure
            psycho-corporelle commune, transdiagnostique, que nous appelons le
            <strong> mental restrictif</strong>.
          </p>
          <p>
            C'est en travaillant cette structure, en même temps que le rapport au corps et à
            l'alimentation, que s'ouvre une trajectoire de soin durable.
          </p>
        </div>
        <div class="intent-card">
          <div class="intent-card-value">3</div>
          <p>axes en synergie : psychique, corporel et diététique.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cream">
    <div class="inner reveal">
      <div class="section-head">
        <div class="section-head-text">
          <div class="section-label">Qui peut consulter</div>
          <h2>Le cabinet accompagne</h2>
        </div>
      </div>
      <div class="divider-gold"></div>
      <div class="public-grid">
        {publics.map((publicItem) => (
          <article class="public-card">
            <h3>{publicItem.titre}</h3>
            <p>{publicItem.texte}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="axes-showcase">
    <div class="inner reveal">
      <div class="axes-heading">
        <div class="section-label">Les trois axes du cabinet</div>
        <h2>Trois spécialités, <em>une même trajectoire de soin</em></h2>
        <p class="axes-lead">
          Il ne s'agit pas de trois suivis en parallèle, mais d'un accompagnement articulé,
          où chaque axe éclaire et soutient les deux autres.
        </p>
      </div>

      <div class="axes-stack">
        {axes.map((axe) => (
          <article class="axis-row">
            <div class="axis-number">{axe.numero}</div>
            <div class="axis-content">
              <h3>{axe.titre}</h3>
              <p>{axe.description}</p>
            </div>
            <div class="axis-praticiens">{axe.praticiens}</div>
          </article>
        ))}
      </div>

      <div class="axes-footer-note">
        Les apports décrits pour chaque spécialité sont indicatifs. La trajectoire de soin se
        construit avec chaque personne accompagnée ; elle n'est ni protocolisée ni généralisable.
      </div>

      <div class="axes-actions">
        <a href="/equipe" class="btn-primary btn-primary-light">Voir l'équipe en détail</a>
      </div>
    </div>
  </section>

  <section class="mr-section" id="mental-restrictif">
    <div class="inner-narrow reveal">
      <div class="section-label">La notion qui organise notre approche</div>
      <h2>Le <em>mental restrictif</em></h2>
      <div class="divider-gold" style="background: var(--gold-light); margin-top: 1.5rem;"></div>
      <p class="mr-lede">
        Une organisation psychique transdiagnostique qui se retrouve derrière l'anorexie, la
        boulimie et l'hyperphagie.
      </p>
      <p>
        C'est une modalité d'être faite de contrôle, de rigidité et d'hyperadaptation, qui se
        met en place quand la sécurité intérieure est fragilisée.
      </p>
      <p>
        Comprendre le mental restrictif, c'est souvent le premier pas d'un soin qui ne se
        contente plus d'agir sur les symptômes.
      </p>
      <div class="mr-actions">
        <a href="/mental-restrictif" class="btn-primary">Comprendre le mental restrictif</a>
      </div>
    </div>
  </section>

  <section class="bg-cream" id="ressources">
    <div class="inner reveal">
      <div class="livre-grid">
        <div class="livre-visuel">
          <img
            src="/images/rehault-sortir-anorexie.jpg"
            alt="Couverture du livre Sortir de l'anorexie et de la boulimie d'Aude Réhault"
          />
        </div>
        <div class="livre-content">
          <div class="section-label">Pour approfondir</div>
          <h2>Sortir de l'anorexie <em>et de la boulimie</em></h2>
          <div class="author">Aude Réhault · Éditions Dunod</div>
          <div class="divider-gold"></div>
          <p>
            Un ouvrage qui synthétise l'approche clinique : comment construire une trajectoire
            de soin qui tienne compte de la structure psycho-corporelle du TCA, au-delà du seul
            travail sur les symptômes.
          </p>
          <div class="btn-group">
            <a
              href="https://www.dunod.com/sciences-humaines-et-sociales/sortir-anorexie-et-boulimie-construire-sa-trajectoire-soin"
              class="btn-primary btn-primary-light"
              target="_blank"
              rel="noopener"
            >
              Voir sur le site de l'éditeur
            </a>
            <a href="/ressources" class="btn-secondary btn-secondary-dark">Toutes les ressources</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="rdv-section" id="contact">
    <div class="inner reveal">
      <div class="rdv-grid home-rdv-grid">
        <div class="rdv-left">
          <div class="section-label">Prendre rendez-vous</div>
          <h2>Un premier rendez-vous <em>au cabinet</em></h2>
          <div class="divider-gold"></div>
          <p>
            Les rendez-vous se prennent directement en ligne sur Doctolib. Vous pouvez cibler
            un praticien si vous savez qui vous souhaitez consulter, ou commencer par une
            première prise de contact.
          </p>
          <div class="rdv-cta-group">
            <a
              href="https://www.doctolib.fr/cabinet-pluridisciplinaire/nantes/sos-anor-grand-ouest?pid=practice-103988"
              class="btn-primary btn-primary-light"
              target="_blank"
              rel="noopener"
            >
              Prendre rendez-vous
            </a>
            <a href="/equipe" class="btn-secondary btn-secondary-dark">Choisir un praticien</a>
          </div>
        </div>
        <aside class="rdv-right location-card">
          <div class="label">Nous trouver</div>
          <h3>Cabinet La Note Bleue</h3>
          <address>
            <strong>Nantes</strong><br />
            6 et 7 rue des Rochettes<br />
            44000 Nantes
          </address>
          <p class="location-note">
            Un lieu unique pour permettre la circulation discrète de l'information clinique entre
            praticiens.
          </p>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  .home-hero {
    padding-top: clamp(3rem, 4vw, 4.5rem);
    padding-bottom: clamp(4.5rem, 8vw, 7rem);
    background:
      radial-gradient(circle at top left, rgba(232, 201, 154, 0.18), transparent 28%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.7), rgba(245, 242, 238, 0.8));
  }

  .home-hero-shell {
    width: min(100%, var(--container-wide));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.78fr);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: stretch;
  }

  .home-hero-copy {
    position: relative;
    background: linear-gradient(155deg, var(--blue-deep), #27476c 52%, #2d5477 100%);
    color: white;
    padding: clamp(2rem, 4vw, 4rem);
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(24, 45, 69, 0.2);
  }

  .home-hero-copy::before {
    content: '';
    position: absolute;
    inset: auto -10% -18% auto;
    width: 360px;
    height: 360px;
    border-radius: 50%;
    border: 1px solid rgba(232, 201, 154, 0.22);
    box-shadow:
      0 0 0 36px rgba(232, 201, 154, 0.06),
      0 0 0 72px rgba(232, 201, 154, 0.04);
    pointer-events: none;
  }

  .home-hero-copy::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(125deg, transparent 0%, transparent 58%, rgba(255, 255, 255, 0.06) 100%),
      radial-gradient(circle at 15% 15%, rgba(255, 255, 255, 0.08), transparent 22%);
    pointer-events: none;
  }

  .hero-kicker {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 1rem;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(232, 201, 154, 0.25);
    border-radius: 999px;
    color: var(--gold-light);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 1.6rem;
  }

  .home-hero h1 {
    position: relative;
    z-index: 1;
    max-width: 12ch;
    font-size: clamp(2.8rem, 6vw, 5.35rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: white;
    margin-bottom: 1.5rem;
    text-wrap: balance;
  }

  .home-hero h1 em {
    color: var(--gold-light);
    font-style: italic;
    font-weight: 400;
  }

  .hero-intro {
    position: relative;
    z-index: 1;
    max-width: 62ch;
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1rem, 0.95rem + 0.35vw, 1.18rem);
    line-height: 1.85;
    margin-bottom: 2.2rem;
  }

  .hero-actions {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero-panel {
    position: relative;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(30, 58, 95, 0.08);
    border-radius: 24px;
    padding: clamp(1.5rem, 2vw, 2rem);
    box-shadow: 0 18px 60px rgba(30, 58, 95, 0.08);
    align-self: end;
  }

  .hero-panel::before {
    content: '';
    position: absolute;
    inset: 1rem;
    border: 1px solid rgba(196, 149, 90, 0.18);
    border-radius: 18px;
    pointer-events: none;
  }

  .hero-panel-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-deep);
    margin-bottom: 1.1rem;
  }

  .hero-panel-list {
    list-style: none;
    display: grid;
    gap: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .hero-panel-list li {
    position: relative;
    padding-left: 1.3rem;
    color: var(--text-dark);
    line-height: 1.65;
  }

  .hero-panel-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--gold);
  }

  .hero-panel-note {
    color: var(--text-mid);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(30, 58, 95, 0.1);
  }

  .hero-panel-link {
    color: var(--blue-deep);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .hero-panel-link:hover {
    color: var(--gold-deep);
  }

  .home-intent {
    position: relative;
  }

  .home-intent::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(100% - 2.4rem, 1180px);
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(30, 58, 95, 0.1), transparent);
  }

  .home-head {
    margin-bottom: 1.7rem;
  }

  .intent-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(220px, 0.72fr);
    gap: 2rem;
    align-items: start;
  }

  .intent-prose p {
    font-size: 1.05rem;
    color: var(--text-mid);
    line-height: 1.9;
    margin-bottom: 1rem;
  }

  .intent-prose strong {
    color: var(--blue-deep);
  }

  .intent-card {
    padding: 1.8rem;
    border-radius: 24px;
    background: linear-gradient(180deg, var(--cream), rgba(234, 242, 248, 0.75));
    border: 1px solid rgba(30, 58, 95, 0.08);
    text-align: left;
  }

  .intent-card-value {
    font-family: 'Playfair Display', serif;
    font-size: 4.5rem;
    line-height: 1;
    color: var(--gold-deep);
    margin-bottom: 0.7rem;
  }

  .intent-card p {
    color: var(--text-mid);
    line-height: 1.75;
  }

  .public-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.35rem;
  }

  .public-card {
    position: relative;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(30, 58, 95, 0.08);
    border-radius: 20px;
    padding: 2rem 1.7rem;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .public-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--gold), rgba(196, 149, 90, 0.2));
  }

  .public-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 14px 34px rgba(30, 58, 95, 0.08);
  }

  .public-card h3 {
    font-size: 1.25rem;
    color: var(--blue-deep);
    margin-bottom: 0.9rem;
    line-height: 1.3;
  }

  .public-card p {
    color: var(--text-mid);
    line-height: 1.8;
  }

  .axes-showcase {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(245, 242, 238, 0.6)),
      radial-gradient(circle at 100% 0%, rgba(197, 216, 236, 0.3), transparent 30%);
  }

  .axes-heading {
    max-width: 760px;
    margin-bottom: 3rem;
  }

  .axes-lead {
    margin-top: 1.2rem;
    color: var(--text-mid);
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .axes-stack {
    display: grid;
    gap: 1rem;
  }

  .axis-row {
    display: grid;
    grid-template-columns: 90px minmax(0, 1.3fr) minmax(220px, 0.8fr);
    gap: 1.3rem;
    align-items: start;
    padding: 1.6rem;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(30, 58, 95, 0.08);
    border-radius: 22px;
    box-shadow: 0 12px 30px rgba(30, 58, 95, 0.04);
  }

  .axis-number {
    font-family: 'Playfair Display', serif;
    font-size: 2.3rem;
    line-height: 1;
    color: var(--gold);
    font-style: italic;
    padding-top: 0.2rem;
  }

  .axis-content h3 {
    font-size: 1.3rem;
    color: var(--blue-deep);
    margin-bottom: 0.7rem;
    line-height: 1.3;
  }

  .axis-content p {
    color: var(--text-mid);
    line-height: 1.85;
  }

  .axis-praticiens {
    color: var(--gold-deep);
    font-size: 0.84rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.7;
    font-weight: 700;
    padding-top: 0.25rem;
  }

  .axes-footer-note {
    margin-top: 1.6rem;
    padding: 1.3rem 1.5rem;
    background: rgba(255, 255, 255, 0.8);
    border-left: 3px solid var(--gold);
    border-radius: 0 16px 16px 0;
    color: var(--text-mid);
    font-size: 0.95rem;
    line-height: 1.75;
    font-style: italic;
  }

  .axes-actions {
    margin-top: 2rem;
  }

  .mr-actions {
    margin-top: 2.2rem;
  }

  .home-rdv-grid {
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
  }

  .location-card {
    position: relative;
    overflow: hidden;
  }

  .location-card::after {
    content: '';
    position: absolute;
    right: -40px;
    bottom: -70px;
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196, 149, 90, 0.16), transparent 68%);
    pointer-events: none;
  }

  .location-note {
    margin-top: 1.3rem;
    color: var(--text-mid);
    line-height: 1.75;
    max-width: 36ch;
  }

  @media (max-width: 1024px) {
    .home-hero-shell,
    .intent-grid,
    .public-grid,
    .home-rdv-grid {
      grid-template-columns: 1fr;
    }

    .axis-row {
      grid-template-columns: 70px 1fr;
    }

    .axis-praticiens {
      grid-column: 2;
      padding-top: 0;
    }
  }

  @media (max-width: 768px) {
    .home-hero {
      padding-top: 1.5rem;
    }

    .home-hero-copy,
    .hero-panel,
    .public-card,
    .axis-row {
      border-radius: 18px;
    }

    .home-hero h1 {
      max-width: none;
    }

    .hero-kicker {
      border-radius: 18px;
      line-height: 1.5;
    }

    .axis-row {
      grid-template-columns: 1fr;
    }

    .axis-number,
    .axis-praticiens {
      grid-column: auto;
    }
  }
</style>
