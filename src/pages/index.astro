<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cabinet La Note Bleue · Nantes | Trajectoire de soin des troubles alimentaires</title>
  <meta name="description" content="Cabinet pluridisciplinaire nantais spécialisé dans la trajectoire de soin des troubles des conduites alimentaires. Psychologie, diététique, psychomotricité, en synergie.">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://cabinet-lanotebleue-nantes.fr">

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Mulish:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    /* === Design system (déclinaison sœur — Variante B · Clinique) === */
:root {
  --blue-deep: #1e3a5f;
  --blue-mid: #2c4a6e;
  --blue-soft: #4a7ca8;
  --blue-mist: #c5d8ec;
  --blue-pale: #eaf2f8;
  --cream: #faf8f5;
  --warm-white: #f5f2ee;
  --gold: #c4955a;
  --gold-light: #e8c99a;
  --gold-deep: #a87939;
  --text-dark: #1a2e42;
  --text-mid: #3d5a72;
  --text-light: #7a9ab5;
  --border: #dce8f0;

  /* Tokens spécifiques Variante B — densité clinique, accents or soutenus */
  --bg-primary: var(--warm-white);
  --bg-structured: var(--blue-deep);
  --accent: var(--gold);

  /* Containers & rythme global */
  --container: 1120px;
  --container-wide: 1240px;
  --container-narrow: 820px;
  --gutter: clamp(1.2rem, 2vw, 2.5rem);
  --section-y: clamp(4.5rem, 7vw, 6rem);
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  font-family: 'Mulish', sans-serif;
  font-weight: 400;
  color: var(--text-dark);
  background: var(--bg-primary);
  line-height: 1.65;
}

h1, h2, h3, h4 {
  font-family: 'Playfair Display', serif;
  font-weight: 500;
}

/* === Top strip — discret, signe de cabinet === */
.top-strip {
  background: var(--blue-deep);
  color: var(--gold-light);
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 0.55rem var(--gutter);
  text-align: center;
  font-weight: 500;
}
.top-strip .sep { opacity: 0.35; margin: 0 0.9rem; }

/* === Navigation === */
nav {
  position: sticky;
  top: 0;
  background: white;
  border-bottom: 1px solid var(--border);
  height: 82px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--gutter);
  z-index: 500;
  box-shadow: 0 1px 0 0 rgba(30, 58, 95, 0.03);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: 0.9rem;
  color: var(--blue-deep);
}

.nav-logo-emblem {
  width: 44px;
  height: 44px;
  background: var(--blue-deep);
  color: var(--gold-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  font-style: italic;
  font-weight: 500;
  border: 2px solid var(--gold);
  border-radius: 6px;
}

.nav-logo-text {
  display: flex;
  flex-direction: column;
  line-height: 1.1;
  font-family: 'Playfair Display', serif;
}

.nav-logo-text strong {
  font-size: 1.08rem;
  font-weight: 600;
  color: var(--blue-deep);
}

.nav-logo-text small {
  font-size: 0.68rem;
  color: var(--gold-deep);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-family: 'Mulish', sans-serif;
  font-weight: 700;
  margin-top: 3px;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 2rem;
  list-style: none;
}

.nav-links a {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--text-dark);
  text-decoration: none;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.5rem 0;
  border-bottom: 2px solid transparent;
  transition: all 0.25s;
}

.nav-links a:hover {
  color: var(--gold-deep);
  border-bottom-color: var(--gold);
}

.nav-cta {
  background: var(--gold);
  color: var(--blue-deep);
  padding: 0.75rem 1.5rem;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  border: none;
  cursor: pointer;
  transition: all 0.25s;
  text-decoration: none;
  border-radius: 6px;
}

.nav-cta:hover {
  background: var(--gold-deep);
  color: white;
}

/* === Hero === */
.hero {
  background: var(--blue-deep);
  color: white;
  padding: clamp(5rem, 8vw, 6.5rem) var(--gutter) clamp(5.5rem, 9vw, 7rem);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 85% 30%, rgba(196, 149, 90, 0.15) 0%, transparent 50%),
    radial-gradient(circle at 10% 80%, rgba(74, 124, 168, 0.2) 0%, transparent 60%);
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: -1px;
  width: 120px;
  height: 4px;
  background: var(--gold);
}

.hero-inner {
  width: min(100%, var(--container-wide));
  margin: 0 auto;
  position: relative;
  z-index: 2;
}

.hero-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: var(--gold-light);
  margin-bottom: 2rem;
  padding-bottom: 1.2rem;
  border-bottom: 1px solid rgba(232, 201, 154, 0.3);
  max-width: min(100%, 760px);
}

.hero h1 {
  font-size: clamp(2.4rem, 4.8vw, 4.35rem);
  line-height: 1.08;
  color: white;
  margin-bottom: 2rem;
  font-weight: 500;
  letter-spacing: -0.005em;
  max-width: min(100%, 1100px);
  text-wrap: balance;
}

.hero h1 em {
  font-style: italic;
  color: var(--gold-light);
  font-weight: 400;
}

.hero-lede {
  font-size: clamp(1rem, 0.96rem + 0.3vw, 1.15rem);
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.85);
  max-width: min(100%, 900px);
  margin-bottom: 3rem;
  font-weight: 300;
  text-wrap: pretty;
}

.hero-cta-group {
  display: flex;
  gap: 1.5rem;
  align-items: center;
  flex-wrap: wrap;
}

.btn-primary {
  background: var(--gold);
  color: var(--blue-deep);
  padding: 1.05rem 2.2rem;
  font-family: 'Mulish', sans-serif;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.25s;
  display: inline-flex;
  align-items: center;
  gap: 0.7rem;
  border: 2px solid var(--gold);
  border-radius: 6px;
}

.btn-primary:hover {
  background: transparent;
  color: var(--gold-light);
  box-shadow: 0 0 0 1px var(--gold-light);
}

.btn-secondary {
  color: white;
  font-family: 'Mulish', sans-serif;
  font-size: 0.82rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 1.05rem 1.5rem;
  border: 2px solid rgba(255, 255, 255, 0.3);
  transition: all 0.25s;
  border-radius: 6px;
}

.btn-secondary:hover {
  border-color: var(--gold-light);
  color: var(--gold-light);
}

.btn-primary-light {
  background: var(--blue-deep);
  color: white;
  border-color: var(--blue-deep);
}

.btn-primary-light:hover {
  background: var(--blue-mid);
  color: var(--gold-light);
  border-color: var(--blue-mid);
}

.btn-secondary-dark {
  color: var(--blue-deep);
  border-color: rgba(30, 58, 95, 0.2);
}

.btn-secondary-dark:hover {
  color: var(--gold-deep);
  border-color: var(--gold);
}

/* === Sections === */
section {
  padding: var(--section-y) var(--gutter);
}

.inner {
  width: min(100%, var(--container));
  margin: 0 auto;
}

.inner-narrow {
  width: min(100%, var(--container-narrow));
  margin: 0 auto;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 1.3rem;
  margin-bottom: 2.5rem;
}

.section-numero {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 1.6rem;
  color: var(--gold);
  font-weight: 400;
  min-width: 44px;
  line-height: 1;
}

.section-head-text {
  flex: 1;
}

.section-label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.24em;
  text-transform: uppercase;
  color: var(--gold-deep);
  margin-bottom: 0.6rem;
}

h2 {
  font-size: clamp(1.8rem, 3.4vw, 2.6rem);
  color: var(--blue-deep);
  line-height: 1.2;
  font-weight: 600;
}

h2 em {
  font-style: italic;
  color: var(--gold-deep);
  font-weight: 400;
}

.divider-gold {
  width: 56px;
  height: 3px;
  background: var(--gold);
  margin-bottom: 1.8rem;
}

/* === Section présentation === */
.bg-cream { background: var(--cream); }
.bg-warm-white { background: var(--warm-white); }
.bg-white { background: white; }

.presentation-grid {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 4rem;
}

.presentation-text p {
  font-size: 1rem;
  color: var(--text-mid);
  margin-bottom: 1.2rem;
  line-height: 1.85;
}

.presentation-text strong {
  color: var(--blue-deep);
  font-weight: 600;
}

.presentation-aside {
  background: var(--blue-deep);
  color: white;
  padding: 2.5rem;
  border-top: 4px solid var(--gold);
  font-size: 0.9rem;
  line-height: 1.8;
  border-radius: 8px;
}

.presentation-aside .label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold-light);
  margin-bottom: 1rem;
}

.presentation-aside p {
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 1rem;
}

.presentation-aside a {
  color: var(--gold-light);
  text-decoration: none;
  border-bottom: 1px solid var(--gold);
  font-weight: 600;
}

.presentation-aside a:hover {
  color: white;
}

/* === Section Qui === */
.qui-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 3rem;
}

.qui-card {
  background: white;
  padding: 2.5rem 2rem;
  border-left: 3px solid var(--gold);
  transition: all 0.3s;
  border-radius: 10px;
}

.qui-card:hover {
  border-left-width: 6px;
  box-shadow: 0 6px 30px rgba(30, 58, 95, 0.1);
}

.qui-card h3 {
  font-size: 1.2rem;
  color: var(--blue-deep);
  margin-bottom: 1rem;
  font-weight: 600;
  line-height: 1.3;
}

.qui-card p {
  font-size: 0.92rem;
  color: var(--text-mid);
  line-height: 1.75;
}

/* === Section Trois axes === */
.axes-intro {
  margin-bottom: 4rem;
}

.axes-intro > div:empty {
  display: none;
}

.axes-lede {
  text-align: center;
  max-width: 900px;
  margin: 0 auto;
  font-size: 1.05rem;
  color: var(--text-mid);
  line-height: 1.8;
}

.axes-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.2rem;
}

.axe-card {
  background: white;
  padding: 3rem 2.2rem;
  border: 1px solid var(--border);
  border-radius: 10px;
  position: relative;
  transition: all 0.3s;
  overflow: hidden;
}

.axe-card:hover {
  background: var(--cream);
  box-shadow: 0 6px 28px rgba(30, 58, 95, 0.08);
}

.axe-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: var(--gold);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.4s;
}

.axe-card:hover::before {
  transform: scaleX(1);
}

.axe-numero {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 2.2rem;
  color: var(--gold);
  font-weight: 400;
  line-height: 1;
  margin-bottom: 1rem;
}

.axe-card h3 {
  font-size: 1.2rem;
  color: var(--blue-deep);
  margin-bottom: 1rem;
  font-weight: 600;
  line-height: 1.3;
  min-height: 3rem;
}

.axe-card p {
  font-size: 0.92rem;
  color: var(--text-mid);
  line-height: 1.75;
  margin-bottom: 1.5rem;
}

.axe-card .praticiens {
  font-size: 0.78rem;
  color: var(--gold-deep);
  padding-top: 1.2rem;
  border-top: 1px dashed var(--border);
  font-weight: 600;
  letter-spacing: 0.05em;
}

.axes-mention {
  margin-top: 2.5rem;
  padding: 1.5rem 2rem;
  background: var(--cream);
  border-left: 3px solid var(--gold);
  font-size: 0.88rem;
  font-style: italic;
  color: var(--text-mid);
  line-height: 1.75;
  border-radius: 6px;
}

.axes-cta {
  margin-top: 3rem;
}

/* === Section mental restrictif === */
.mr-section {
  background: var(--blue-deep);
  color: white;
  padding: clamp(5.5rem, 9vw, 7rem) var(--gutter);
  position: relative;
  overflow: hidden;
}

.mr-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4px;
  background: linear-gradient(90deg, transparent, var(--gold) 30%, var(--gold) 70%, transparent);
}

.mr-section .section-label {
  color: var(--gold-light);
}

.mr-section h2 {
  color: white;
  font-size: clamp(2rem, 4vw, 3rem);
}

.mr-section h2 em {
  color: var(--gold-light);
}

.mr-section p {
  font-size: 1.02rem;
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 1.3rem;
}

.mr-section strong {
  color: var(--gold-light);
  font-weight: 600;
}

.mr-lede {
  font-size: 1.15rem !important;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.92) !important;
  margin-bottom: 2rem !important;
  padding-bottom: 2rem;
  border-bottom: 1px solid rgba(232, 201, 154, 0.2);
}

/* === Section livre === */
.livre-grid {
  display: grid;
  grid-template-columns: 0.9fr 1.6fr;
  gap: 4rem;
  align-items: center;
}

.livre-visuel {
  position: relative;
}

.livre-visuel::before {
  content: '';
  position: absolute;
  top: 20px;
  right: -20px;
  width: 100%;
  height: 100%;
  background: var(--gold);
  opacity: 0.15;
  z-index: 0;
}

.livre-visuel img {
  position: relative;
  z-index: 1;
  max-width: 100%;
  box-shadow: 0 20px 50px rgba(30, 58, 95, 0.22);
  border-radius: 4px;
}

.livre-content h2 {
  margin-bottom: 1rem;
}

.livre-content .author {
  font-style: italic;
  color: var(--gold-deep);
  margin-bottom: 1.5rem;
  font-family: 'Playfair Display', serif;
  font-size: 1.05rem;
}

.livre-content p {
  font-size: 1rem;
  color: var(--text-mid);
  line-height: 1.85;
  margin-bottom: 2rem;
}

.livre-content .btn-group {
  display: flex;
  gap: 1.2rem;
  align-items: center;
  flex-wrap: wrap;
}

/* === Section rendez-vous === */
.rdv-section {
  background: white;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.rdv-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.rdv-left h2 {
  margin-bottom: 1.5rem;
}

.rdv-left p {
  font-size: 1.02rem;
  color: var(--text-mid);
  line-height: 1.8;
  margin-bottom: 2rem;
}

.rdv-cta-group {
  display: flex;
  gap: 1.2rem;
  flex-wrap: wrap;
}

.rdv-right {
  background: var(--cream);
  padding: 3rem;
  border-top: 4px solid var(--gold);
  border-radius: 10px;
}

.rdv-right .label {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold-deep);
  margin-bottom: 1rem;
}

.rdv-right h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  color: var(--blue-deep);
  margin-bottom: 1.5rem;
  font-weight: 500;
}

.rdv-right address {
  font-style: normal;
  font-size: 0.95rem;
  color: var(--text-mid);
  line-height: 1.8;
}

.rdv-right address strong {
  color: var(--blue-deep);
  font-weight: 600;
}

/* === Footer === */
footer {
  background: var(--blue-deep);
  color: white;
  padding: clamp(4rem, 6vw, 5rem) var(--gutter) 2rem;
  position: relative;
}

footer::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 4px;
  background: var(--gold);
}

.footer-content {
  width: min(100%, var(--container));
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  gap: 3rem;
  padding-bottom: 3rem;
  border-bottom: 1px solid rgba(255, 255, 255, 0.12);
}

.footer-section h3 {
  font-family: 'Mulish', sans-serif;
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--gold-light);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 1.3rem;
  padding-bottom: 0.7rem;
  border-bottom: 1px solid rgba(232, 201, 154, 0.25);
}

.footer-section p,
.footer-section li {
  font-size: 0.86rem;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.82);
}

.footer-section ul {
  list-style: none;
}

.footer-section a {
  color: rgba(255, 255, 255, 0.82);
  text-decoration: none;
  transition: color 0.25s;
}

.footer-section a:hover {
  color: var(--gold-light);
}

.footer-brand {
  display: flex;
  align-items: center;
  gap: 0.9rem;
  margin-bottom: 1.2rem;
}

.footer-brand-emblem {
  width: 44px;
  height: 44px;
  background: transparent;
  color: var(--gold-light);
  border: 2px solid var(--gold);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 1.3rem;
  border-radius: 6px;
}

.footer-brand-text {
  font-family: 'Playfair Display', serif;
  display: flex;
  flex-direction: column;
  line-height: 1.1;
}

.footer-brand-text strong {
  font-size: 1.1rem;
  font-weight: 600;
}

.footer-brand-text small {
  font-size: 0.68rem;
  color: var(--gold-light);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  font-family: 'Mulish', sans-serif;
  font-weight: 700;
  margin-top: 4px;
}

.footer-bottom {
  width: min(100%, var(--container));
  margin: 2rem auto 0;
  display: flex;
  justify-content: space-between;
  font-size: 0.74rem;
  color: rgba(255, 255, 255, 0.55);
  flex-wrap: wrap;
  gap: 1rem;
}

.footer-bottom a {
  color: rgba(255, 255, 255, 0.7);
  text-decoration: none;
}

.footer-bottom a:hover {
  color: var(--gold-light);
}

/* === Scroll reveal === */
.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.9s cubic-bezier(0.2, 0.9, 0.3, 1);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* === Responsive === */
@media (max-width: 1366px) {
  .hero-inner {
    width: min(100%, 1180px);
  }

  .hero h1 {
    max-width: 1000px;
  }

  .hero-lede {
    max-width: 840px;
  }
}

@media (max-width: 1024px) {
  .presentation-grid,
  .livre-grid,
  .rdv-grid {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  .qui-grid,
  .axes-grid {
    grid-template-columns: 1fr;
  }

  .footer-content {
    grid-template-columns: 1fr 1fr;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    line-height: 1.1;
  }
}

@media (max-width: 768px) {
  .top-strip {
    font-size: 0.65rem;
    padding: 0.45rem 1rem;
  }

  .top-strip .sep {
    display: none;
  }

  nav {
    padding: 0 1.2rem;
    height: 72px;
  }

  .nav-links {
    display: none;
  }

  .hero {
