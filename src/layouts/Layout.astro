---
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = "Cabinet pluridisciplinaire nantais spécialisé dans la trajectoire de soin des troubles des conduites alimentaires. Psychologie, diététique, psychomotricité, en synergie.",
  canonicalPath = "",
  noindex = false,
  ogType = "website",
} = Astro.props;

const siteUrl = "https://cabinet-lanotebleue-nantes.fr";
const resolvedPath = canonicalPath || Astro.url.pathname || "/";
const canonical = new URL(resolvedPath || "/", siteUrl).toString();
const robots = noindex ? "noindex, nofollow" : "index, follow";
const currentPath = Astro.url.pathname;
const currentYear = new Date().getFullYear();

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  name: "Cabinet La Note Bleue",
  url: siteUrl,
  description,
  image: `${siteUrl}/favicon.svg`,
  address: {
    "@type": "PostalAddress",
    streetAddress: "6 et 7 rue des Rochettes",
    postalCode: "44000",
    addressLocality: "Nantes",
    addressCountry: "FR",
  },
  areaServed: "Nantes",
  availableLanguage: ["fr"],
  sameAs: [
    "https://association-lanotebleue.fr",
    "https://www.doctolib.fr/cabinet-pluridisciplinaire/nantes/sos-anor-grand-ouest?pid=practice-103988",
  ],
};

const webpageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: title,
  url: canonical,
  description,
  inLanguage: "fr-FR",
  isPartOf: {
    "@type": "WebSite",
    name: "Cabinet La Note Bleue",
    url: siteUrl,
  },
};

const structuredData = JSON.stringify([organizationSchema, webpageSchema]);
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content={robots}>
  <link rel="canonical" href={canonical}>
  <meta name="theme-color" content="#1e3a5f">
  <meta property="og:locale" content="fr_FR">
  <meta property="og:type" content={ogType}>
  <meta property="og:site_name" content="Cabinet La Note Bleue">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="alternate" hreflang="fr-FR" href={canonical}>
  <script type="application/ld+json" set:html={structuredData}></script>

  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Mulish:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style is:global>
    /* === Design system (déclinaison sœur — Variante B · Clinique) === */
    :root {
      --blue-deep: #1e3a5f;
      --blue-mid: #2c4a6e;
      --blue-soft: #4a7ca8;
      --blue-mist: #c5d8ec;
      --blue-pale: #eaf2f8;
      --cream: #faf8f5;
      --warm-white: #f5f2ee;
      --gold: #c4955a;
      --gold-light: #e8c99a;
      --gold-deep: #a87939;
      --text-dark: #1a2e42;
      --text-mid: #3d5a72;
      --text-light: #7a9ab5;
      --text-secondary: var(--text-mid);
      --text-tertiary: var(--text-light);
      --border: #dce8f0;
      --font-display: 'Playfair Display', serif;
      --font-body: 'Mulish', sans-serif;

      /* Tokens spécifiques Variante B — densité clinique, accents or soutenus */
      --bg-primary: var(--warm-white);
      --bg-structured: var(--blue-deep);
      --accent: var(--gold);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      font-weight: 400;
      color: var(--text-dark);
      background: var(--bg-primary);
      line-height: 1.65;
    }

    h1, h2, h3, h4 { font-family: var(--font-display); font-weight: 500; }

    /* === Container générique pour les pages enfants === */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* === Top strip — discret, signe de cabinet === */
    .top-strip {
      background: var(--blue-deep);
      color: var(--gold-light);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.55rem 2rem;
      text-align: center;
      font-weight: 500;
    }
    .top-strip .sep { opacity: 0.35; margin: 0 0.9rem; }

    /* === Navigation === */
    nav {
      position: sticky;
      top: 0;
      background: white;
      border-bottom: 1px solid var(--border);
      height: 82px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      z-index: 500;
      box-shadow: 0 1px 0 0 rgba(30, 58, 95, 0.03);
    }
    .nav-logo {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      color: var(--blue-deep);
      text-decoration: none;
    }
    .nav-logo-emblem {
      width: 44px; height: 44px;
      background: var(--blue-deep);
      color: var(--gold-light);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-style: italic;
      font-weight: 500;
      border: 2px solid var(--gold);
      border-radius: 6px;
    }
    .nav-logo-text {
      display: flex; flex-direction: column; line-height: 1.1;
      font-family: 'Playfair Display', serif;
    }
    .nav-logo-text strong {
      font-size: 1.08rem;
      font-weight: 600;
      color: var(--blue-deep);
    }
    .nav-logo-text small {
      font-size: 0.68rem;
      color: var(--gold-deep);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-family: 'Mulish', sans-serif;
      font-weight: 700;
      margin-top: 3px;
    }

    .nav-links {
      display: flex; align-items: center; gap: 2rem;
      list-style: none;
    }
    .nav-links a {
      font-size: 0.78rem;
      font-weight: 600;
      color: var(--text-dark);
      text-decoration: none;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.5rem 0;
      border-bottom: 2px solid transparent;
      transition: all 0.25s;
    }
    .nav-links a:hover {
      color: var(--gold-deep);
      border-bottom-color: var(--gold);
    }
    .nav-links a[aria-current='page'] {
      color: var(--gold-deep);
      border-bottom-color: var(--gold);
    }

    .nav-cta {
      background: var(--gold);
      color: var(--blue-deep);
      padding: 0.75rem 1.5rem;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border: none;
      cursor: pointer;
      transition: all 0.25s;
      text-decoration: none;
      border-radius: 6px;
    }
    .nav-cta:hover {
      background: var(--gold-deep);
      color: white;
    }
/* === Hamburger mobile === */
.nav-burger {
  display: none;
  width: 36px; height: 36px;
  background: none; border: none;
  padding: 0; margin: 0;
  cursor: pointer;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
}
.nav-burger span {
  display: block;
  width: 24px; height: 2px;
  background: var(--blue-deep);
  border-radius: 2px;
  transition: transform 0.3s ease, opacity 0.3s ease;
}
.nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger.is-open span:nth-child(2) { opacity: 0; }
.nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    main {
      display: block;
    }

    /* === Hero === */
    .hero {
      background: var(--blue-deep);
      color: white;
      padding: 6.5rem 2rem 7rem;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 85% 30%, rgba(196, 149, 90, 0.15) 0%, transparent 50%),
        radial-gradient(circle at 10% 80%, rgba(74, 124, 168, 0.2) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero::after {
      content: '';
      position: absolute;
      left: 50%; transform: translateX(-50%);
      bottom: -1px;
      width: 120px; height: 4px;
      background: var(--gold);
    }
    .hero-inner {
      max-width: 1080px;
      margin: 0 auto;
      position: relative;
      z-index: 2;
    }
    .hero-label {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: var(--gold-light);
      margin-bottom: 2rem;
      padding-bottom: 1.2rem;
      border-bottom: 1px solid rgba(232, 201, 154, 0.3);
      max-width: 620px;
    }
    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 3.8rem);
      line-height: 1.15;
      color: white;
      margin-bottom: 2rem;
      font-weight: 500;
      letter-spacing: -0.005em;
      max-width: 920px;
    }
    .hero h1 em {
      font-style: italic;
      color: var(--gold-light);
      font-weight: 400;
    }
    .hero-lede {
      font-size: 1.1rem;
      line-height: 1.75;
      color: rgba(255, 255, 255, 0.85);
      max-width: 760px;
      margin-bottom: 3rem;
      font-weight: 300;
    }
    .hero-page {
      padding: 4.5rem 2rem 5rem;
    }
    .hero-page h1 {
      font-size: clamp(2rem, 4vw, 3.2rem);
      max-width: 820px;
    }
    .hero-page .hero-lede {
      font-size: 1.05rem;
      max-width: 680px;
      margin-bottom: 0;
    }
    .hero-cta-group {
      display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap;
    }
    .btn-primary {
      background: var(--gold);
      color: var(--blue-deep);
      padding: 1.05rem 2.2rem;
      font-family: 'Mulish', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.25s;
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      border: 2px solid var(--gold);
      border-radius: 6px;
    }
    .btn-primary:hover {
      background: transparent;
      color: var(--gold-light);
      box-shadow: 0 0 0 1px var(--gold-light);
    }
    .btn-group {
      display: flex;
      gap: 1.2rem;
      align-items: center;
      flex-wrap: wrap;
    }
    .btn-secondary {
      color: white;
      font-family: 'Mulish', sans-serif;
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      padding: 1.05rem 1.5rem;
      border: 2px solid rgba(255, 255, 255, 0.3);
      transition: all 0.25s;
      border-radius: 6px;
    }
    .btn-secondary:hover {
      border-color: var(--gold-light);
      color: var(--gold-light);
    }

    .btn-primary-light {
      background: var(--blue-deep);
      color: white;
      border-color: var(--blue-deep);
    }
    .btn-primary-light:hover {
      background: var(--blue-mid);
      color: var(--gold-light);
      border-color: var(--blue-mid);
    }
    .btn-secondary-dark {
      color: var(--blue-deep);
      border-color: rgba(30, 58, 95, 0.2);
    }
    .btn-secondary-dark:hover {
      color: var(--gold-deep);
      border-color: var(--gold);
    }

    /* === Sections === */
    section {
      padding: 6rem 2rem;
    }
    .inner {
      max-width: 1120px;
      margin: 0 auto;
    }
    .inner-narrow {
      max-width: 820px;
      margin: 0 auto;
    }

    .section-head {
      display: flex;
      align-items: center;
      gap: 1.3rem;
      margin-bottom: 2.5rem;
    }
    .section-numero {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.6rem;
      color: var(--gold);
      font-weight: 400;
      min-width: 44px;
      line-height: 1;
    }
    .section-head-text {
      flex: 1;
    }
    .section-head-simple {
      gap: 0;
    }
    .section-head-simple .section-head-text {
      width: 100%;
    }
    .section-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--gold-deep);
      margin-bottom: 0.6rem;
    }
    h2 {
      font-size: clamp(1.8rem, 3.4vw, 2.6rem);
      color: var(--blue-deep);
      line-height: 1.2;
      font-weight: 600;
    }
    h2 em {
      font-style: italic;
      color: var(--gold-deep);
      font-weight: 400;
    }

    .divider-gold {
      width: 56px; height: 3px;
      background: var(--gold);
      margin-bottom: 1.8rem;
    }

    /* === Section présentation === */
    .bg-cream { background: var(--cream); }
    .bg-warm-white { background: var(--warm-white); }
    .bg-white { background: white; }

    .presentation-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 4rem;
    }
    .presentation-text p {
      font-size: 1rem;
      color: var(--text-mid);
      margin-bottom: 1.2rem;
      line-height: 1.85;
    }
    .presentation-text strong {
      color: var(--blue-deep);
      font-weight: 600;
    }
    .prose p {
      font-size: 1rem;
      color: var(--text-mid);
      margin-bottom: 1.3rem;
      line-height: 1.85;
    }
    .prose p:last-child {
      margin-bottom: 0;
    }
    .prose strong {
      color: var(--blue-deep);
      font-weight: 600;
    }
    .presentation-aside {
      background: var(--blue-deep);
      color: white;
      padding: 2.5rem;
      border-top: 4px solid var(--gold);
      font-size: 0.9rem;
      line-height: 1.8;
      border-radius: 8px;
    }
    .presentation-aside .label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--gold-light);
      margin-bottom: 1rem;
    }
    .presentation-aside p {
      color: rgba(255, 255, 255, 0.85);
      margin-bottom: 1rem;
    }
    .presentation-aside a {
      color: var(--gold-light);
      text-decoration: none;
      border-bottom: 1px solid var(--gold);
      font-weight: 600;
    }
    .presentation-aside a:hover {
      color: white;
    }

    /* === Section Qui === */
    .qui-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-top: 3rem;
    }
    .qui-card {
      background: white;
      padding: 2.5rem 2rem;
      border-left: 3px solid var(--gold);
      transition: all 0.3s;
      border-radius: 10px;
    }
    .qui-card:hover {
      border-left-width: 6px;
      box-shadow: 0 6px 30px rgba(30, 58, 95, 0.1);
    }
    .qui-card h3 {
      font-size: 1.2rem;
      color: var(--blue-deep);
      margin-bottom: 1rem;
      font-weight: 600;
      line-height: 1.3;
    }
    .qui-card p {
      font-size: 0.92rem;
      color: var(--text-mid);
      line-height: 1.75;
    }

    /* === Section Trois axes === */
    .axes-intro {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 3rem;
      align-items: start;
      margin-bottom: 4rem;
    }
    .axes-intro h2 {
      margin-bottom: 0;
    }
    .axes-lede {
      font-size: 1.05rem;
      color: var(--text-mid);
      line-height: 1.8;
    }
    .axes-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.2rem;
    }
    .axe-card {
      background: white;
      padding: 3rem 2.2rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      position: relative;
      transition: all 0.3s;
      overflow: hidden;
    }
    .axe-card:hover {
      background: var(--cream);
      box-shadow: 0 6px 28px rgba(30, 58, 95, 0.08);
    }
    .axe-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 3px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 0.4s;
    }
    .axe-card:hover::before {
      transform: scaleX(1);
    }
    .axe-numero {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 2.2rem;
      color: var(--gold);
      font-weight: 400;
      line-height: 1;
      margin-bottom: 1rem;
    }
    .axe-card h3 {
      font-size: 1.2rem;
      color: var(--blue-deep);
      margin-bottom: 1rem;
      font-weight: 600;
      line-height: 1.3;
      min-height: 3rem;
    }
    .axe-card p {
      font-size: 0.92rem;
      color: var(--text-mid);
      line-height: 1.75;
      margin-bottom: 1.5rem;
    }
    .axe-card .praticiens {
      font-size: 0.78rem;
      color: var(--gold-deep);
      padding-top: 1.2rem;
      border-top: 1px dashed var(--border);
      font-weight: 600;
      letter-spacing: 0.05em;
    }

    .axes-mention {
      margin-top: 2.5rem;
      padding: 1.5rem 2rem;
      background: var(--cream);
      border-left: 3px solid var(--gold);
      font-size: 0.88rem;
      font-style: italic;
      color: var(--text-mid);
      line-height: 1.75;
      border-radius: 6px;
    }
    .axes-cta {
      margin-top: 3rem;
    }

    /* === Section mental restrictif === */
    .mr-section {
      background: var(--blue-deep);
      color: white;
      padding: 7rem 2rem;
      position: relative;
      overflow: hidden;
    }
    .mr-section::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 4px;
      background: linear-gradient(90deg, transparent, var(--gold) 30%, var(--gold) 70%, transparent);
    }
    .mr-section .section-label {
      color: var(--gold-light);
    }
    .mr-section h2 {
      color: white;
      font-size: clamp(2rem, 4vw, 3rem);
    }
    .mr-section h2 em {
      color: var(--gold-light);
    }
    .mr-section p {
      font-size: 1.02rem;
      line-height: 1.85;
      color: rgba(255, 255, 255, 0.85);
      margin-bottom: 1.3rem;
    }
    .mr-section strong {
      color: var(--gold-light);
      font-weight: 600;
    }
    .mr-lede {
      font-size: 1.15rem !important;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.92) !important;
      margin-bottom: 2rem !important;
      padding-bottom: 2rem;
      border-bottom: 1px solid rgba(232, 201, 154, 0.2);
    }

    /* === Section livre === */
    .livre-grid {
      display: grid;
      grid-template-columns: 0.9fr 1.6fr;
      gap: 4rem;
      align-items: center;
    }
    .livre-visuel {
      position: relative;
    }
    .livre-visuel::before {
      content: '';
      position: absolute;
      top: 20px; right: -20px;
      width: 100%; height: 100%;
      background: var(--gold);
      opacity: 0.15;
      z-index: 0;
    }
    .livre-visuel img {
      position: relative;
      z-index: 1;
      max-width: 100%;
      box-shadow: 0 20px 50px rgba(30, 58, 95, 0.22);
      border-radius: 4px;
    }
    .livre-content h2 {
      margin-bottom: 1rem;
    }
    .livre-content .author {
      font-style: italic;
      color: var(--gold-deep);
      margin-bottom: 1.5rem;
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem;
    }
    .livre-content p {
      font-size: 1rem;
      color: var(--text-mid);
      line-height: 1.85;
      margin-bottom: 2rem;
    }
    .livre-content .btn-group {
      display: flex; gap: 1.2rem; align-items: center; flex-wrap: wrap;
    }

    /* === Section rendez-vous === */
    .rdv-section {
      background: white;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }
    .rdv-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }
    .rdv-left h2 { margin-bottom: 1.5rem; }
    .rdv-left p {
      font-size: 1.02rem;
      color: var(--text-mid);
      line-height: 1.8;
      margin-bottom: 2rem;
    }
    .rdv-cta-group {
      display: flex; gap: 1.2rem; flex-wrap: wrap;
    }
    .rdv-right {
      background: var(--cream);
      padding: 3rem;
      border-top: 4px solid var(--gold);
      border-radius: 10px;
    }
    .rdv-right .label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--gold-deep);
      margin-bottom: 1rem;
    }
    .rdv-right h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      color: var(--blue-deep);
      margin-bottom: 1.5rem;
      font-weight: 500;
    }
    .rdv-right address {
      font-style: normal;
      font-size: 0.95rem;
      color: var(--text-mid);
      line-height: 1.8;
    }
    .rdv-right address strong {
      color: var(--blue-deep);
      font-weight: 600;
    }

    /* === Footer === */
    footer {
